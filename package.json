{
  "name": "gogo-invoice",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Offline-first invoice generator. No backend — your data lives on your device. Multiple company headers, history, PDF export and JSON backup.",
  "homepage": "https://hallucinogen.github.io/gogo-invoice/",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify": "tsx scripts/verify.tsx && tsx scripts/render-check.tsx && tsx scripts/save-check.tsx",
    "format": "prettier -w .",
    "format:check": "prettier -c ."
  },
  "dependencies": {
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@react-pdf/renderer": "^3.4.5",
    "date-fns": "^3.6.0",
    "file-saver": "^2.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "workbox-window": "^7.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
